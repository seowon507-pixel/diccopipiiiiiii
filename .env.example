VITE_KAKAO_MAP_KEY=여기에_카카오_JavaScript_키_입력
VITE_SUPABASE_URL=여기에_Supabase_프로젝트_URL_입력
VITE_SUPABASE_ANON_KEY=여기에_Supabase_anon_public_키_입력

# 개발 환경에서만 필요한 경우 true로 변경하세요.
VITE_USE_DUMMY_DATA=false
VITE_DEV_LOCATION_OVERRIDE=false

# 아직 보안 Supabase migration을 적용하지 않은 로컬 개발 DB에서만 임시로 사용하세요.
# production build에서는 true여도 무시됩니다.
VITE_ALLOW_LEGACY_BACKEND=false

# 웹 푸시 알림용 공개키입니다.
VITE_VAPID_PUBLIC_KEY=여기에_웹푸시_VAPID_공개키_입력
